<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="refresh" content="3; url=https://kalter.com.br"> <!-- Redireciona em 3 seg -->
    <title>Kalter - Soluções Industriais</title>
    <style>
        body {
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background-color: #f4f4f4;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #333;
        }
        .container {
            text-align: center;
            padding: 40px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }
        .loader {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #0056b3; /* Cor principal da Kalter */
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 20px auto;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        a {
            color: #0056b3;
            text-decoration: none;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="container">
        <h2>Acessando conteúdo...</h2>
        <div class="loader"></div>
        <p>Aguarde um instante.</p>
        <p>Se não for redirecionado, <a href="https://kalter.com.br">clique aqui</a>.</p>
    </div>
    <script>
        // Redirecionamento via JS para maior compatibilidade
        setTimeout(function() {
            window.location.href = "https://kalter.com.br";
        }, 3000);
    </script>
</body>
</html>
